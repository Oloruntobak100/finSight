# Copy to .env for local dev. Production: set on Railway (backend) / Vercel (frontend).
# Never commit real values.

# --- Supabase ---
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- App URLs ---
FASTAPI_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Comma-separated browser origins allowed to call the API (production Vercel URL is also added automatically from FRONTEND_URL)
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Security ---
SECRET_KEY=
# Optional: secures POST /synthetic-feed/cron/live-drip (defaults to SECRET_KEY)
CRON_SECRET=
ENCRYPTION_KEY=

# --- Plaid ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_OPTIONAL_PRODUCTS=liabilities,investments,identity
PLAID_COUNTRY_CODES=US,GB
PLAID_REDIRECT_URI=

# --- Mono ---
MONO_SECRET_KEY=
MONO_PUBLIC_KEY=
ENABLE_SYNTHETIC_FEED=true

# --- QuickBooks ---
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# Intuit redirect URI — must match Developer Portal (frontend callback):
# http://localhost:3000/oauth/quickbooks/callback
# https://your-app.vercel.app/oauth/quickbooks/callback
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENV=sandbox

# --- Xero ---
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=

# --- LLM ---
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Billing / email / cache (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
RESEND_API_KEY=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
